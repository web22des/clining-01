---
// src/components/partials/HeadTheme.astro
import "@styles/global.scss";

export interface Props {
    title?: string;
    description?: string;
    canonicalUrl?: string | URL;
    noIndex?: boolean;
    keywords?: string;
}

// Используем переданные значения или дефолты
const {
    title = "Сборник курсов",
    description = "Сборник различных курсов на разные темы",
    canonicalUrl = new URL(Astro.url.pathname, Astro.site),
    noIndex = false,
    keywords = "курсы, обучение, программирование",
} = Astro.props;
const basePath = import.meta.env.BASE_URL;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<!--  -->

<script is:inline>
    (() => {
        console.log("🎨 [Switcher] Script loaded");

        // ✅ Синхронизация радио-кнопок с текущей темой
        const syncSwitcher = () => {
            console.log("🎨 [Switcher] syncSwitcher started");
            const saved = localStorage.getItem("theme");
            let version = "v_01";
            let mode = "light";

            if (saved) {
                try {
                    const parsed = JSON.parse(saved);
                    version = parsed.version || "v_01";
                    mode = parsed.mode || "light";
                    console.log("🎨 [Switcher] Parsed:", parsed);
                } catch (e) {
                    console.warn("🎨 [Switcher] JSON parse error:", e);
                    localStorage.removeItem("theme");
                }
            }

            const selector = `input[name="theme-version"][value="${version}"]`;
            const checked = document.querySelector(selector);
            console.log("🎨 [Switcher] Found checkbox:", checked);
            if (checked) {
                checked.checked = true;
            }
        };

        // ✅ Обработчик переключения
        const initSwitcher = () => {
            console.log("🎨 [Switcher] initSwitcher started");
            const inputs = document.querySelectorAll(
                'input[name="theme-version"]',
            );
            console.log("🎨 [Switcher] Found inputs:", inputs.length);

            inputs.forEach((input) => {
                input.addEventListener("change", (e) => {
                    console.log("🎨 [Switcher] CHANGE EVENT FIRED!");
                    const newVersion = e.target.value;
                    console.log("🎨 [Switcher] New version:", newVersion);

                    const saved = localStorage.getItem("theme");
                    let currentTheme = { version: "v_01", mode: "light" };

                    if (saved) {
                        try {
                            currentTheme = JSON.parse(saved);
                        } catch (err) {
                            console.warn(
                                "🎨 [Switcher] Parse error on click:",
                                err,
                            );
                        }
                    }

                    const newTheme = {
                        version: newVersion,
                        mode: currentTheme.mode,
                    };
                    localStorage.setItem("theme", JSON.stringify(newTheme));
                    console.log(
                        "🎨 [Switcher] Saved to localStorage:",
                        newTheme,
                    );

                    // ✅ Применяем ОБА атрибута (обязательно!)
                    document.documentElement.setAttribute(
                        "data-theme-version",
                        newVersion,
                    );
                    document.documentElement.setAttribute(
                        "data-theme",
                        currentTheme.mode,
                    );
                    console.log("🎨 [Switcher] Attributes set on html");
                });
            });
        };

        // ✅ Инициализация
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", () => {
                console.log("🎨 [Switcher] DOMContentLoaded");
                syncSwitcher();
                initSwitcher();
            });
        } else {
            console.log("🎨 [Switcher] DOM already loaded");
            syncSwitcher();
            initSwitcher();
        }
    })();
</script>

<!--  -->

<!--  -->
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="sitemap" href="sitemap-index.xml" />
<meta name="generator" content={Astro.generator} />

<!-- Базовые иконки -->
<link rel="icon" href=`${basePath}/favicon/favicon.ico` sizes="any" />
<link rel="icon" href=`${basePath}/favicon/favicon.svg` type="image/svg+xml" />

<!-- Адаптивные иконки -->
<link rel="apple-touch-icon" href=`${basePath}/favicon/apple-touch-icon.png` />
<link rel="manifest" href=`${basePath}/favicon/site.webmanifest` />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalUrl} />

{/* SEO Tags */}
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
{noIndex && <meta name="robots" content="noindex, nofollow" />}

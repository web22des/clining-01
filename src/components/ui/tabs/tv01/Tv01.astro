---
// src/components/ui/tabs/tv01/Tv01.astro
// Компонент табов с динамической генерацией вкладок

import Cv100 from "@components/ui/card/Cv100.astro";
import type { ImageMetadata } from "astro";
import img01 from "@assets/temp/images/552x360-01.jpg";
import img02 from "@assets/temp/images/552x360-02.jpg";
import img03 from "@assets/temp/images/552x360-03.jpg";
import img04 from "@assets/temp/images/552x360-04.jpg";
import img05 from "@assets/temp/images/552x360-05.jpg";

// ✅ Интерфейс одной вкладки (данные для карточки внутри таба)
export interface TabItem {
    id: string; // Уникальный ID (kebab-case)
    title: string; // Заголовок кнопки таба
    cardData: {
        btntext: string;
        src: ImageMetadata;
        alt: string;
        width: number;
        height: number;
    };
}

// ✅ Интерфейс пропсов компонента
export interface Props {
    tabs?: TabItem[]; // Массив вкладок (опционально, есть дефолт)
    class?: string; // Дополнительные классы
    id?: string; // ID секции для якорей
}

// ✅ Дефолтные данные (5 вкладок с карточками)
const defaultTabs: TabItem[] = [
    {
        id: "tab-01",
        title: "Таб №1",
        cardData: {
            btntext: "Подробнее",
            src: img01,
            alt: "Описание изображения 1",
            width: 552,
            height: 360,
        },
    },
    {
        id: "tab-02",
        title: "Таб №2",
        cardData: {
            btntext: "Подробнее",
            src: img02,
            alt: "Описание изображения 2",
            width: 552,
            height: 360,
        },
    },
    {
        id: "tab-03",
        title: "Таб №3",
        cardData: {
            btntext: "Подробнее",
            src: img03,
            alt: "Описание изображения 3",
            width: 552,
            height: 360,
        },
    },
    {
        id: "tab-04",
        title: "Таб №4",
        cardData: {
            btntext: "Подробнее",
            src: img04,
            alt: "Описание изображения 4",
            width: 552,
            height: 360,
        },
    },
    {
        id: "tab-05",
        title: "Таб №5",
        cardData: {
            btntext: "Подробнее",
            src: img05,
            alt: "Описание изображения 5",
            width: 552,
            height: 360,
        },
    },
];

// ✅ Деструктуризация пропсов
const {
    tabs = defaultTabs,
    class: className = "",
    id: sectionId = "tabs-default",
} = Astro.props;
---

<!-- ✅ Контейнер табов -->
<div data-tabs class="tabs {className}" id={sectionId}>
    <!-- ✅ Навигация (кнопки табов) - рендерится динамически -->
    <nav data-tabs-titles class="tabs__navigation" role="tablist">
        {
            tabs.map((tab, index) => (
                <button
                    type="button"
                    class={`tabs__title ${index === 0 ? "_tab-active" : ""}`}
                    role="tab"
                    aria-selected={index === 0 ? "true" : "false"}
                    aria-controls={`panel-${tab.id}`}
                >
                    {tab.title}
                </button>
            ))
        }
    </nav>

    <!-- ✅ Контент табов (панели) - рендерится динамически -->
    <div data-tabs-body class="tabs__content">
        {
            tabs.map((tab, index) => (
                <div
                    class="tabs__body"
                    id={`panel-${tab.id}`}
                    role="tabpanel"
                    hidden={index !== 0}
                >
                    <Cv100 {...tab.cardData} />
                </div>
            ))
        }
    </div>
</div>

<style lang="scss">
    .tabs {
        &__navigation {
            padding: 8px 4px;
            margin-bottom: 24px;
            display: flex;
            flex-wrap: wrap;
            //flex-direction: column;
            gap: 8px;
        }
        &__title {
            display: inline-block;
            font-size: var(--font-size-lable-large);
            color: var(--md-sys-color-on-surface-variant);
            padding: 6px 12px;
            border: 1px solid var(--md-sys-color-on-surface-variant);
            border-radius: var(--border-radius-medium);
        }

        &__title._tab-active {
            border: 1px solid var(--md-sys-color-primary);
            background-color: var(--md-sys-color-primary);
            color: var(--md-sys-color-on-primary);
        }
    }
</style>
